{
  "manifest_version": 2,
  "name": "Collection Structure Manager",
  "version": "0.6.2",
  "description": "Safely inspect and manage Zotero collection structure.",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "applications": {
    "zotero": {
      "id": "collection-structure-manager@plugin.local",
      "update_url": "https://example.com/zotero-collection-structure-manager-plugin/updates.json",
      "strict_min_version": "7.0",
      "strict_max_version": "7.0.*"
    }
  }
}
